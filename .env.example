# ERP CONSTRUSMART — Example env (copia a .env.local)
# Reemplaza los valores placeholder con los reales de tu proyecto Supabase

# Obligatorias
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_KEY=tu-anon-key-publica

# Service Role Key (para migraciones y scripts de administración)
# Obtén esto desde: Supabase Dashboard → Settings → API → service_role (secret)
VITE_SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Connection String PostgreSQL (para migraciones directas)
# Formato: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# Obtén esto desde: Supabase Dashboard → Settings → Database → Connection String → URI
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Opcionales
VITE_ADMIN_EMAIL=admin@example.com
VITE_APP_ENV=development

# Google OAuth — la app usa Google como único proveedor de autenticación
