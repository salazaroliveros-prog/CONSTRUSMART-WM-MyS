# ERP CONSTRUSMART - Example env (copia a .env; NO subas .env a git)

# 1) Supabase (obligatorio para auth y datos remotos)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_KEY=tu-anon-key-aqui

# 2) Identidad operativa
VITE_APP_NAME=erp-construsmart

# 3) Google OAuth hosted domain (opcional — restringe login a un dominio corporativo)
# Ej: VITE_GOOGLE_OAUTH_HD=constructora-wm.com
# Déjalo vacío/comentado para permitir cualquier cuenta @gmail.com
VITE_GOOGLE_OAUTH_HD=

# 4) Entorno
VITE_APP_ENV=development

# NOTA DE SEGURIDAD:
# El único Administrador total es salazaroliveros@gmail.com.
# Los demás usuarios autorizados deben tener rol en Supabase (Administrador/Gerente/Residente/Compras/Bodeguero).
# Mantener RLS activado por tabla y revisar políticas de rol periódicamente.
