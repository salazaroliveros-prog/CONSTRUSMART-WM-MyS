# ERP CONSTRUSMART - Variables de entorno
# Copiá este archivo a .env (no lo subas a git) y completá con tus valores reales.

# 1) Supabase (obligatorio para auth y datos remotos)
#    La URL del proyecto, Ej: https://xyzcompany.supabase.co
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
#    La anon/public key del proyecto (Settings → API → anon public)
VITE_SUPABASE_KEY=tu-anon-key-aqui

# 2) Nombre del paquete (opcional, se usa para analytics/metadatos)
VITE_APP_NAME=erp-construsmart

# 3) Entorno (development | production)
VITE_APP_ENV=development
