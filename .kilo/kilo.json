{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "agent-platform-mcp": {
      "type": "remote",
      "url": "https://aiplatform.googleapis.com/mcp/generate"
    },
    "data-lineage-mcp": {
      "type": "remote",
      "url": "https://datalineage.googleapis.com/mcp"
    },
    "n8n-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "n8n-mcp@2.12.2"
      ],
      "environment": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true"
      }
    },
    "time": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-time"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@0.0.38"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "{{DEFAULT_MINIMUM_TOKENS}}"
      }
    },
    "gcp-pubsub": {
      "type": "remote",
      "url": "https://pubsub.googleapis.com/mcp"
    }
  }
}
